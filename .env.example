OPENAI_API_KEY=your-api-key-here
DATABASE_URL=sqlite:///reminders.db
# DATABASE_URL=postgresql://user:pass@localhost:5432/tami

# 360dialog WhatsApp
D360_API_KEY=your-d360-api-key
D360_API_BASE_URL=https://waba-v2.360dialog.io

# Webhook auth (none | bearer | basic)
WEBHOOK_AUTH_MODE=none
# WEBHOOK_BEARER_TOKEN=your-bearer-token
# WEBHOOK_BASIC_USER=user
# WEBHOOK_BASIC_PASS=pass

# OpenAI transcription
OPENAI_TRANSCRIBE_MODEL=gpt-4o-transcribe
OPENAI_MODEL=gpt-5.4-mini

# LangSmith tracing
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=echo2
LANGSMITH_TRACING_V2=false

# Transcription provider (openai | modal)
TRANSCRIPTION_PROVIDER=openai
# MODAL_TRANSCRIPTION_URL=
# MODAL_TRANSCRIPTION_KEY=
# MODAL_TRANSCRIPTION_SECRET=
# MODAL_TRANSCRIPTION_TIMEOUT_SECONDS=180

# Conversation settings
CONVERSATION_MAX_MESSAGES=20
ALLOWED_CHAT_IDS=
DATABASE_PATH=tami.db
MAX_GROUP_PARTICIPANTS=3
SESSION_GAP_MINUTES=45
CONVERSATION_DORMANT_HOURS=24
CONVERSATION_CLOSED_DAYS=7
WAITING_REPLY_HOURS=4
MAX_EXTRACTION_ATTEMPTS=3
CONVERSATION_HISTORY_CONTEXT_MESSAGES=10

# Tenant
TENANT_TIMEZONE=Asia/Jerusalem
LOG_LEVEL=INFO

# Compiled agent
COMPILED_AGENT_PATH=compiled_agent.json

# Review keywords
REVIEW_START_KEYWORD=בוא
REVIEW_END_KEYWORD=בטל
REVIEW_CLARIFICATION_LIMIT=3
